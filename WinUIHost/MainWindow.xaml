<Window
    x:Class="ExplorerPlusPlus.WinUIHost.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Explorer++ WinUI Host">
    <Grid x:Name="RootLayout" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ItemsControl Grid.Row="0" ItemsSource="{Binding Tabs}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,0,8,0" Padding="10,6" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <TextBlock Text="{Binding Title}" />
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <StackPanel Grid.Row="1" Margin="0,12,0,12" Orientation="Horizontal" Spacing="8">
            <Button Content="Back" Command="{Binding GoBackCommand}" IsEnabled="{Binding Navigation.CanGoBack}" />
            <Button Content="Forward" Command="{Binding GoForwardCommand}" IsEnabled="{Binding Navigation.CanGoForward}" />
            <Button Content="Up" Command="{Binding GoUpCommand}" IsEnabled="{Binding Navigation.CanGoUp}" />
            <Button Content="Refresh" Command="{Binding RefreshCommand}" IsEnabled="{Binding Navigation.CanRefresh}" />
            <TextBox Width="480" Text="{Binding Navigation.CurrentPath}" IsReadOnly="True" />
        </StackPanel>

        <Grid Grid.Row="2" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Padding="8,10,8,10" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <Grid>
                    <ListView x:Name="FoldersPaneListView" ItemsSource="{Binding FolderPane}" SelectedItem="{Binding SelectedFolder, Mode=TwoWay}" BorderThickness="0" Background="Transparent" IsItemClickEnabled="True" ItemClick="FoldersPaneListView_ItemClick" SelectionChanged="FoldersPaneListView_SelectionChanged" SelectionMode="Single" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="36">
                                    <Border Margin="0,0,4,0" Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="8" Opacity="{Binding SelectedBackgroundOpacity}" />
                                    <Border Width="3" Margin="0,6,0,6" HorizontalAlignment="Left" Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="0,2,2,0" Opacity="{Binding SelectionBarOpacity}" />
                                    <Grid Margin="{Binding IndentMargin}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="20" />
                                            <ColumnDefinition Width="22" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <FontIcon Grid.Column="0" Glyph="{Binding ExpandIndicator}" FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="{Binding ChevronOpacity}" />

                                        <FontIcon Grid.Column="1" Glyph="{Binding Glyph}" FontSize="14" VerticalAlignment="Center" />

                                        <TextBlock Grid.Column="2" Text="{Binding Title}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                    </Grid>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <Border Grid.Column="1" Padding="12" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="File list" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock Margin="0,4,0,12" Text="Live filesystem-backed browsing scaffold for the first host shell." Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    <ListView x:Name="FilesListView" ItemsSource="{Binding Files}" BorderThickness="0" Background="Transparent" IsItemClickEnabled="True" ItemClick="FilesListView_ItemClick">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="0,8" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="120" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="{Binding Glyph}" FontSize="14" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding ItemType}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2" Text="{Binding Size}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
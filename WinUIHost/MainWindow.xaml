<Window
    x:Class="ExplorerPlusPlus.WinUIHost.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:ExplorerPlusPlus.WinUIHost.Controls"
    Title="Explorer++ WinUI Host">
    <Grid x:Name="RootLayout" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.RowSpan="2" Background="{ThemeResource ShellTopBarBrush}" />
        <Border Grid.Row="2" Background="{ThemeResource ShellChromeBrush}" />

        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="44">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="TitleBarLeftInsetColumn" Width="16" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="TitleBarRightInsetColumn" Width="138" />
            </Grid.ColumnDefinitions>

            <Border Grid.ColumnSpan="4" Height="1" VerticalAlignment="Bottom" Background="{ThemeResource ShellBorderBrush}" />

            <ItemsControl Grid.Column="1" Margin="0,7,0,0" VerticalAlignment="Bottom" ItemsSource="{Binding Tabs}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border MinWidth="150" Height="36" Margin="0,0,8,0" Padding="14,0,14,0" VerticalAlignment="Bottom" Background="{ThemeResource ShellSurfaceBrush}" BorderBrush="{ThemeResource ShellBorderBrush}" BorderThickness="1,1,1,0" CornerRadius="10,10,0,0">
                            <Grid ColumnSpacing="8" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <FontIcon Grid.Column="0" Glyph="{Binding Glyph}" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="{ThemeResource ShellSecondaryTextBrush}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Foreground="{ThemeResource ShellTextBrush}" Text="{Binding Title}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="16,10,16,10" ColumnSpacing="8">
                <Grid.Resources>
                    <Style x:Key="NavToolbarButtonStyle" TargetType="Button">
                        <Setter Property="Width" Value="30" />
                        <Setter Property="Height" Value="30" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="MinWidth" Value="30" />
                        <Setter Property="MinHeight" Value="30" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderBrush" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="CornerRadius" Value="8" />
                        <Setter Property="Foreground" Value="{ThemeResource ShellTextBrush}" />
                    </Style>
                </Grid.Resources>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Style="{StaticResource NavToolbarButtonStyle}" Command="{Binding GoBackCommand}" IsEnabled="{Binding Navigation.CanGoBack}" PointerEntered="NavToolbarButton_PointerEntered" PointerExited="NavToolbarButton_PointerExited" PointerPressed="NavToolbarButton_PointerPressed" PointerReleased="NavToolbarButton_PointerReleased" PointerCanceled="NavToolbarButton_PointerCanceled" PointerCaptureLost="NavToolbarButton_PointerCaptureLost">
                    <FontIcon Glyph="&#xE72B;" FontFamily="Segoe Fluent Icons" FontSize="13" Foreground="{ThemeResource ShellTextBrush}" />
                </Button>
                <Button Grid.Column="1" Style="{StaticResource NavToolbarButtonStyle}" Command="{Binding GoForwardCommand}" IsEnabled="{Binding Navigation.CanGoForward}" PointerEntered="NavToolbarButton_PointerEntered" PointerExited="NavToolbarButton_PointerExited" PointerPressed="NavToolbarButton_PointerPressed" PointerReleased="NavToolbarButton_PointerReleased" PointerCanceled="NavToolbarButton_PointerCanceled" PointerCaptureLost="NavToolbarButton_PointerCaptureLost">
                    <FontIcon Glyph="&#xE72A;" FontFamily="Segoe Fluent Icons" FontSize="13" Foreground="{ThemeResource ShellTextBrush}" />
                </Button>
                <Button Grid.Column="2" Style="{StaticResource NavToolbarButtonStyle}" Command="{Binding GoUpCommand}" IsEnabled="{Binding Navigation.CanGoUp}" PointerEntered="NavToolbarButton_PointerEntered" PointerExited="NavToolbarButton_PointerExited" PointerPressed="NavToolbarButton_PointerPressed" PointerReleased="NavToolbarButton_PointerReleased" PointerCanceled="NavToolbarButton_PointerCanceled" PointerCaptureLost="NavToolbarButton_PointerCaptureLost">
                    <FontIcon Glyph="&#xE74A;" FontFamily="Segoe Fluent Icons" FontSize="13" Foreground="{ThemeResource ShellTextBrush}" />
                </Button>
                <Button Grid.Column="3" Style="{StaticResource NavToolbarButtonStyle}" Command="{Binding RefreshCommand}" IsEnabled="{Binding Navigation.CanRefresh}" PointerEntered="NavToolbarButton_PointerEntered" PointerExited="NavToolbarButton_PointerExited" PointerPressed="NavToolbarButton_PointerPressed" PointerReleased="NavToolbarButton_PointerReleased" PointerCanceled="NavToolbarButton_PointerCanceled" PointerCaptureLost="NavToolbarButton_PointerCaptureLost">
                    <FontIcon Glyph="&#xE72C;" FontFamily="Segoe Fluent Icons" FontSize="13" Foreground="{ThemeResource ShellTextBrush}" />
                </Button>

                <Border Grid.Column="4" Background="{ThemeResource ShellInputBackgroundBrush}" BorderBrush="{ThemeResource ShellBorderBrush}" BorderThickness="1" CornerRadius="8" Tapped="AddressBar_Tapped">
                    <Grid MinHeight="36">
                        <ItemsControl Margin="12,0" ItemsSource="{Binding Navigation.BreadcrumbSegments}" VerticalAlignment="Center" Visibility="{Binding Navigation.BreadcrumbVisibility}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE76C;" FontFamily="Segoe Fluent Icons" FontSize="10" Foreground="{ThemeResource ShellSecondaryTextBrush}" VerticalAlignment="Center" Visibility="{Binding SeparatorVisibility}" />
                                        <FontIcon Glyph="{Binding Glyph}" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="{ThemeResource ShellTextBrush}" VerticalAlignment="Center" Visibility="{Binding GlyphVisibility}" />
                                        <TextBlock Foreground="{ThemeResource ShellTextBrush}" Text="{Binding Text}" VerticalAlignment="Center" Visibility="{Binding TextVisibility}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBox x:Name="AddressPathTextBox" Margin="12,0" Padding="0,9,0,7" Background="Transparent" BorderThickness="0" Foreground="{ThemeResource ShellTextBrush}" IsReadOnly="True" KeyDown="AddressPathTextBox_KeyDown" LostFocus="AddressPathTextBox_LostFocus" Text="{Binding Navigation.PathText}" Visibility="{Binding Navigation.PathTextVisibility}" />
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="1" Margin="16,0,16,0" Height="1" Background="{ThemeResource ShellBorderBrush}" />
        </Grid>

        <Grid Grid.Row="2" Margin="16,0,16,16" ColumnSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,16,0,0">
                <ListView x:Name="FoldersPaneListView" Margin="0,0,0,0" Background="Transparent" BorderThickness="0" IsItemClickEnabled="True" ItemClick="FoldersPaneListView_ItemClick" ItemsSource="{Binding FolderPane}" ScrollViewer.HorizontalScrollBarVisibility="Disabled" SelectionMode="None">
                    <ListView.Resources>
                        <SolidColorBrush x:Key="ListViewItemBackgroundPointerOver" Color="Transparent" />
                        <SolidColorBrush x:Key="ListViewItemBackgroundPressed" Color="Transparent" />
                        <SolidColorBrush x:Key="ListViewItemBackgroundSelected" Color="Transparent" />
                        <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver" Color="Transparent" />
                        <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPressed" Color="Transparent" />
                    </ListView.Resources>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="MinHeight" Value="0" />
                            <Setter Property="Padding" Value="0" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,2">
                                <StackPanel Margin="14,8,14,8" Visibility="{Binding HeaderVisibility}">
                                    <Border Height="1" Background="{ThemeResource ShellBorderBrush}" Margin="0,6,0,10" />
                                    <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource ShellSidebarSectionBrush}" Text="{Binding Title}" TextWrapping="Wrap" />
                                </StackPanel>
                                <controls:HoverCursorGrid Height="36" PointerEntered="FolderPaneRow_PointerEntered" PointerExited="FolderPaneRow_PointerExited" PointerPressed="FolderPaneRow_PointerPressed" Visibility="{Binding RowVisibility}">
                                    <Border Margin="6,0" Background="{ThemeResource ShellSelectionBrush}" CornerRadius="9" Opacity="{Binding RowBackgroundOpacity}" />
                                    <Grid Margin="{Binding IndentMargin}" VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="6" />
                                            <ColumnDefinition Width="18" />
                                            <ColumnDefinition Width="20" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Width="3" Height="16" Background="{ThemeResource ShellAccentBrush}" CornerRadius="2" HorizontalAlignment="Left" Opacity="{Binding SelectionBarOpacity}" VerticalAlignment="Center" />
                                        <Grid Grid.Column="1" Width="18" Height="18" DataContext="{Binding}" IsHitTestVisible="{Binding ChevronHitTestVisible}" Opacity="{Binding ChevronOpacity}" Tapped="FolderPaneChevron_Tapped" VerticalAlignment="Center">
                                            <FontIcon Glyph="{Binding ExpandIndicator}" FontFamily="Segoe Fluent Icons" FontSize="10" Foreground="{ThemeResource ShellSecondaryTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Grid>
                                        <Grid Grid.Column="2" Width="16" Height="16" VerticalAlignment="Center">
                                            <Image Width="16" Height="16" Opacity="{Binding NativeIconOpacity}" Source="{Binding IconSource}" Stretch="Uniform" />
                                            <FontIcon Glyph="{Binding Glyph}" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="{ThemeResource ShellTextBrush}" HorizontalAlignment="Center" Opacity="{Binding GlyphOpacity}" VerticalAlignment="Center" />
                                        </Grid>
                                        <TextBlock Grid.Column="3" Margin="10,0,10,0" Foreground="{ThemeResource ShellTextBrush}" Text="{Binding Title}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                    </Grid>
                                </controls:HoverCursorGrid>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <Border Grid.Column="1" Margin="0,16,0,0" Background="{ThemeResource ShellSurfaceBrush}" BorderBrush="{ThemeResource ShellBorderBrush}" BorderThickness="1" CornerRadius="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Margin="16,16,16,8" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="120" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource ShellSecondaryTextBrush}" Text="Name" />
                        <TextBlock Grid.Column="1" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource ShellSecondaryTextBrush}" Text="Type" />
                        <TextBlock Grid.Column="2" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource ShellSecondaryTextBrush}" Text="Modified" />
                        <TextBlock Grid.Column="3" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource ShellSecondaryTextBrush}" Text="Size" />
                    </Grid>

                    <ListView x:Name="FilesListView" Grid.Row="1" Margin="8,0,8,8" Background="Transparent" BorderThickness="0" IsItemClickEnabled="True" ItemClick="FilesListView_ItemClick" ItemsSource="{Binding Files}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="8,2" Padding="8,8" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="120" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                        <Grid Width="16" Height="16" VerticalAlignment="Center">
                                            <Image Width="16" Height="16" Opacity="{Binding NativeIconOpacity}" Source="{Binding IconSource}" Stretch="Uniform" />
                                            <FontIcon Glyph="{Binding Glyph}" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="{ThemeResource ShellTextBrush}" HorizontalAlignment="Center" Opacity="{Binding GlyphOpacity}" VerticalAlignment="Center" />
                                        </Grid>
                                        <TextBlock Foreground="{ThemeResource ShellTextBrush}" Text="{Binding Name}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Foreground="{ThemeResource ShellSecondaryTextBrush}" Text="{Binding ItemType}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2" Foreground="{ThemeResource ShellSecondaryTextBrush}" Text="{Binding Modified}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="3" Foreground="{ThemeResource ShellSecondaryTextBrush}" HorizontalAlignment="Right" Text="{Binding Size}" VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
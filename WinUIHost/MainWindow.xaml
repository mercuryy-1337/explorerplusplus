<Window
    x:Class="ExplorerPlusPlus.WinUIHost.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:ExplorerPlusPlus.WinUIHost.Controls"
    xmlns:models="using:ExplorerPlusPlus.WinUIHost.Models"
    Title="ExplorerX">
    <Grid x:Name="RootLayout" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{ThemeResource ShellTopBarBrush}" />
        <Border Grid.Row="2" Background="{ThemeResource ShellChromeBrush}" />
        <Border Grid.Row="3" Background="{ThemeResource ShellChromeBrush}" />

        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="44">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="TitleBarLeftInsetColumn" Width="16" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="TitleBarRightInsetColumn" Width="138" />
            </Grid.ColumnDefinitions>

            <Grid x:Name="TabViewHost" Grid.Column="1" Grid.ColumnSpan="2" VerticalAlignment="Bottom" />
        </Grid>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{ThemeResource ShellChromeBrush}" />

            <Grid Grid.Row="0" Margin="16,10,16,10" ColumnSpacing="8">
                <Grid.Resources>
                    <SolidColorBrush x:Key="ButtonBackgroundDisabled" Color="Transparent" />
                    <SolidColorBrush x:Key="ButtonBorderBrushDisabled" Color="Transparent" />
                    <Style x:Key="NavToolbarButtonStyle" TargetType="Button">
                        <Setter Property="Width" Value="28" />
                        <Setter Property="Height" Value="28" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="MinWidth" Value="28" />
                        <Setter Property="MinHeight" Value="28" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderBrush" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="CornerRadius" Value="6" />
                        <Setter Property="Foreground" Value="{ThemeResource ShellTextBrush}" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="{TemplateBinding CornerRadius}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Grid.Resources>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button x:Name="BackButton" Grid.Column="0" Style="{StaticResource NavToolbarButtonStyle}" Command="{Binding GoBackCommand}" IsEnabled="{Binding Navigation.CanGoBack}" IsEnabledChanged="NavToolbarButton_IsEnabledChanged" Loaded="NavToolbarButton_Loaded" PointerEntered="NavToolbarButton_PointerEntered" PointerExited="NavToolbarButton_PointerExited" PointerPressed="NavToolbarButton_PointerPressed" PointerReleased="NavToolbarButton_PointerReleased" PointerCanceled="NavToolbarButton_PointerCanceled" PointerCaptureLost="NavToolbarButton_PointerCaptureLost">
                    <FontIcon Glyph="&#xE72B;" FontFamily="Segoe Fluent Icons" FontSize="13" Foreground="{Binding Foreground, ElementName=BackButton}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Button>
                <Button x:Name="ForwardButton" Grid.Column="1" Style="{StaticResource NavToolbarButtonStyle}" Command="{Binding GoForwardCommand}" IsEnabled="{Binding Navigation.CanGoForward}" IsEnabledChanged="NavToolbarButton_IsEnabledChanged" Loaded="NavToolbarButton_Loaded" PointerEntered="NavToolbarButton_PointerEntered" PointerExited="NavToolbarButton_PointerExited" PointerPressed="NavToolbarButton_PointerPressed" PointerReleased="NavToolbarButton_PointerReleased" PointerCanceled="NavToolbarButton_PointerCanceled" PointerCaptureLost="NavToolbarButton_PointerCaptureLost">
                    <FontIcon Glyph="&#xE72A;" FontFamily="Segoe Fluent Icons" FontSize="13" Foreground="{Binding Foreground, ElementName=ForwardButton}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Button>
                <Button x:Name="UpButton" Grid.Column="2" Style="{StaticResource NavToolbarButtonStyle}" Command="{Binding GoUpCommand}" IsEnabled="{Binding Navigation.CanGoUp}" IsEnabledChanged="NavToolbarButton_IsEnabledChanged" Loaded="NavToolbarButton_Loaded" PointerEntered="NavToolbarButton_PointerEntered" PointerExited="NavToolbarButton_PointerExited" PointerPressed="NavToolbarButton_PointerPressed" PointerReleased="NavToolbarButton_PointerReleased" PointerCanceled="NavToolbarButton_PointerCanceled" PointerCaptureLost="NavToolbarButton_PointerCaptureLost">
                    <FontIcon Glyph="&#xE74A;" FontFamily="Segoe Fluent Icons" FontSize="13" Foreground="{Binding Foreground, ElementName=UpButton}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Button>
                <Button x:Name="RefreshButton" Grid.Column="3" Style="{StaticResource NavToolbarButtonStyle}" Command="{Binding RefreshCommand}" IsEnabled="{Binding Navigation.CanRefresh}" IsEnabledChanged="NavToolbarButton_IsEnabledChanged" Loaded="NavToolbarButton_Loaded" PointerEntered="NavToolbarButton_PointerEntered" PointerExited="NavToolbarButton_PointerExited" PointerPressed="NavToolbarButton_PointerPressed" PointerReleased="NavToolbarButton_PointerReleased" PointerCanceled="NavToolbarButton_PointerCanceled" PointerCaptureLost="NavToolbarButton_PointerCaptureLost">
                    <FontIcon Glyph="&#xE72C;" FontFamily="Segoe Fluent Icons" FontSize="13" Foreground="{Binding Foreground, ElementName=RefreshButton}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Button>

                <Border Grid.Column="4" Background="{ThemeResource ShellInputBackgroundBrush}" BorderBrush="{ThemeResource ShellBorderBrush}" BorderThickness="1" CornerRadius="8" Tapped="AddressBar_Tapped">
                    <Grid MinHeight="36">
                        <ItemsControl Margin="12,0" ItemsSource="{Binding Navigation.BreadcrumbSegments}" VerticalAlignment="Center" Visibility="{Binding Navigation.BreadcrumbVisibility}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE76C;" FontFamily="Segoe Fluent Icons" FontSize="10" Foreground="{ThemeResource ShellSecondaryTextBrush}" VerticalAlignment="Center" Visibility="{Binding SeparatorVisibility}" />
                                        <FontIcon Glyph="{Binding Glyph}" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="{ThemeResource ShellTextBrush}" VerticalAlignment="Center" Visibility="{Binding GlyphVisibility}" />
                                        <TextBlock Foreground="{ThemeResource ShellTextBrush}" Text="{Binding Text}" VerticalAlignment="Center" Visibility="{Binding TextVisibility}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBox x:Name="AddressPathTextBox" Margin="12,0" Padding="0,9,0,7" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" Foreground="{ThemeResource ShellTextBrush}" IsReadOnly="False" KeyDown="AddressPathTextBox_KeyDown" LostFocus="AddressPathTextBox_LostFocus" Text="{Binding Navigation.PathText, Mode=TwoWay}" Visibility="{Binding Navigation.PathTextVisibility}" />
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="1" Margin="16,0,16,0" Height="1" Background="{ThemeResource ShellBorderBrush}" />
        </Grid>

        <Grid Grid.Row="2" Margin="16,0,16,0" ColumnSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,16,0,0">
                <ListView x:Name="FoldersPaneListView" Margin="0,0,0,0" Background="Transparent" BorderThickness="0" ItemsSource="{Binding FolderPane}" ScrollViewer.HorizontalScrollBarVisibility="Disabled" SelectionMode="None">
                    <ListView.Resources>
                        <SolidColorBrush x:Key="ListViewItemBackgroundPointerOver" Color="Transparent" />
                        <SolidColorBrush x:Key="ListViewItemBackgroundPressed" Color="Transparent" />
                        <SolidColorBrush x:Key="ListViewItemBackgroundSelected" Color="Transparent" />
                        <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver" Color="Transparent" />
                        <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPressed" Color="Transparent" />
                    </ListView.Resources>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="MinHeight" Value="0" />
                            <Setter Property="Padding" Value="0" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,2">
                                <StackPanel Margin="14,8,14,8" Visibility="{Binding HeaderVisibility}">
                                    <Border Height="1" Background="{ThemeResource ShellBorderBrush}" Margin="0,6,0,10" />
                                    <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource ShellSidebarSectionBrush}" Text="{Binding Title}" TextWrapping="Wrap" />
                                </StackPanel>
                                <Grid Height="36" Background="Transparent" PointerEntered="FolderPaneRow_PointerEntered" PointerExited="FolderPaneRow_PointerExited" PointerPressed="FolderPaneRow_PointerPressed" PointerReleased="FolderPaneRow_PointerReleased" RightTapped="FolderPaneRow_RightTapped" Visibility="{Binding RowVisibility}">
                                    <Border Margin="6,0" Background="{ThemeResource ShellSelectionBrush}" CornerRadius="9" Opacity="{Binding RowBackgroundOpacity}" />
                                    <Grid IsHitTestVisible="False" Margin="{Binding IndentMargin}" VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="6" />
                                            <ColumnDefinition Width="26" />
                                            <ColumnDefinition Width="20" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Width="3" Height="16" Background="{ThemeResource ShellAccentBrush}" CornerRadius="2" HorizontalAlignment="Left" Opacity="{Binding SelectionBarOpacity}" VerticalAlignment="Center" />
                                        <Grid Grid.Column="1" Width="26" Height="26" Opacity="{Binding ChevronOpacity}" VerticalAlignment="Center">
                                            <FontIcon Glyph="{Binding ExpandIndicator}" FontFamily="Segoe Fluent Icons" FontSize="10" Foreground="{ThemeResource ShellSecondaryTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Grid>
                                        <Grid Grid.Column="2" Width="16" Height="16" VerticalAlignment="Center">
                                            <Image Width="16" Height="16" Opacity="{Binding NativeIconOpacity}" Source="{Binding IconSource}" Stretch="Uniform" />
                                            <FontIcon Glyph="{Binding Glyph}" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="{ThemeResource ShellTextBrush}" HorizontalAlignment="Center" Opacity="{Binding GlyphOpacity}" VerticalAlignment="Center" />
                                        </Grid>
                                        <TextBlock Grid.Column="3" Margin="10,0,10,0" Foreground="{ThemeResource ShellTextBrush}" Text="{Binding Title}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                    </Grid>
                                    <controls:HoverCursorGrid Margin="6,0,0,0" Width="{Binding ExpandHitAreaWidth}" Background="Transparent" HorizontalAlignment="Left" IsHitTestVisible="{Binding ChevronHitTestVisible}" Tapped="FolderPaneExpandZone_Tapped" UseArrowCursor="True" />
                                    <controls:HoverCursorGrid Margin="{Binding ActivateHitAreaMargin}" Background="Transparent" PointerReleased="FolderPaneRow_PointerReleased" Tapped="FolderPaneRow_Tapped" />
                                </Grid>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <Grid Grid.Column="1" Margin="0,8,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{ThemeResource ShellTopBarBrush}" BorderBrush="{ThemeResource ShellBorderBrush}" BorderThickness="1" CornerRadius="12">
                    <Grid MinHeight="54" Padding="12,8">
                        <Grid.Resources>
                            <Style x:Key="CommandBarButtonStyle" TargetType="Button">
                                <Setter Property="Padding" Value="10,6" />
                                <Setter Property="MinHeight" Value="32" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderBrush" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="CornerRadius" Value="8" />
                                <Setter Property="Foreground" Value="{ThemeResource ShellTextBrush}" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="RootBorder" Background="{TemplateBinding Background}" CornerRadius="{TemplateBinding CornerRadius}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>

                                            <VisualStateManager.VisualStateGroups>
                                                <VisualStateGroup x:Name="CommonStates">
                                                    <VisualState x:Name="Normal" />
                                                    <VisualState x:Name="PointerOver">
                                                        <Storyboard>
                                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="Background">
                                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource ShellNavButtonHoverBrush}" />
                                                            </ObjectAnimationUsingKeyFrames>
                                                        </Storyboard>
                                                    </VisualState>
                                                    <VisualState x:Name="Pressed">
                                                        <Storyboard>
                                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="Background">
                                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource ShellNavButtonPressedBrush}" />
                                                            </ObjectAnimationUsingKeyFrames>
                                                        </Storyboard>
                                                    </VisualState>
                                                    <VisualState x:Name="Disabled">
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0.45" Duration="0" />
                                                        </Storyboard>
                                                    </VisualState>
                                                </VisualStateGroup>
                                            </VisualStateManager.VisualStateGroups>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>

                            <Style x:Key="CommandBarIconButtonStyle" TargetType="Button" BasedOn="{StaticResource CommandBarButtonStyle}">
                                <Setter Property="Width" Value="34" />
                                <Setter Property="Padding" Value="0" />
                            </Style>
                        </Grid.Resources>

                        <Grid ColumnSpacing="10" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Example action bar / toolbar content, replace with actual commands and bindings as needed -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                                <Button Style="{StaticResource CommandBarButtonStyle}">
                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE710;" FontFamily="Segoe Fluent Icons" FontSize="14" />
                                        <TextBlock Text="New" VerticalAlignment="Center" />
                                        <FontIcon Glyph="&#xE70D;" FontFamily="Segoe Fluent Icons" FontSize="10" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>

                                <Border Width="1" Height="20" Margin="6,0" Background="{ThemeResource ShellBorderBrush}" VerticalAlignment="Center" />

                                <Button Style="{StaticResource CommandBarIconButtonStyle}">
                                    <FontIcon Glyph="&#xE8C6;" FontFamily="Segoe Fluent Icons" FontSize="14" />
                                </Button>
                                <Button Style="{StaticResource CommandBarIconButtonStyle}">
                                    <FontIcon Glyph="&#xE8C8;" FontFamily="Segoe Fluent Icons" FontSize="14" />
                                </Button>
                                <Button Style="{StaticResource CommandBarIconButtonStyle}">
                                    <FontIcon Glyph="&#xE77F;" FontFamily="Segoe Fluent Icons" FontSize="14" />
                                </Button>
                                <Button Style="{StaticResource CommandBarIconButtonStyle}">
                                    <FontIcon Glyph="&#xE70F;" FontFamily="Segoe Fluent Icons" FontSize="14" />
                                </Button>
                                <Button Style="{StaticResource CommandBarIconButtonStyle}">
                                    <FontIcon Glyph="&#xE72D;" FontFamily="Segoe Fluent Icons" FontSize="14" />
                                </Button>
                                <Button Style="{StaticResource CommandBarIconButtonStyle}">
                                    <FontIcon Glyph="&#xE74D;" FontFamily="Segoe Fluent Icons" FontSize="14" />
                                </Button>

                                <Border Width="1" Height="20" Margin="6,0" Background="{ThemeResource ShellBorderBrush}" VerticalAlignment="Center" />

                                <Button Style="{StaticResource CommandBarButtonStyle}">
                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <TextBlock Text="Sort" VerticalAlignment="Center" />
                                        <FontIcon Glyph="&#xE70D;" FontFamily="Segoe Fluent Icons" FontSize="10" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource CommandBarButtonStyle}">
                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <TextBlock Text="View" VerticalAlignment="Center" />
                                        <FontIcon Glyph="&#xE70D;" FontFamily="Segoe Fluent Icons" FontSize="10" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource CommandBarIconButtonStyle}">
                                    <FontIcon Glyph="&#xE712;" FontFamily="Segoe Fluent Icons" FontSize="14" />
                                </Button>
                            </StackPanel>

                            <Button Grid.Column="1" Style="{StaticResource CommandBarButtonStyle}">
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xECA5;" FontFamily="Segoe Fluent Icons" FontSize="14" />
                                    <TextBlock Text="Details" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Background="{ThemeResource ShellChromeBrush}" />

                <Border Grid.Row="1" Margin="0,12,0,0" Background="{ThemeResource ShellSurfaceBrush}" BorderBrush="{ThemeResource ShellBorderBrush}" BorderThickness="1" CornerRadius="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Margin="16,16,16,8" MinHeight="32" Visibility="{Binding FileListHeaderVisibility}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="1" />
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="1" />
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="1" />
                                <ColumnDefinition Width="120" />
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0">
                                <Border Background="Transparent" />
                                <Button Background="Transparent" BorderBrush="Transparent" BorderThickness="0" Command="{Binding SortFilesCommand}" CommandParameter="Name" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" MinHeight="28" Padding="8,4,8,4" PointerEntered="FileListHeaderButton_PointerEntered" PointerExited="FileListHeaderButton_PointerExited" PointerPressed="FileListHeaderButton_PointerPressed" PointerReleased="FileListHeaderButton_PointerReleased" PointerCanceled="FileListHeaderButton_PointerCanceled" PointerCaptureLost="FileListHeaderButton_PointerCaptureLost" UseSystemFocusVisuals="False">
                                    <Button.Resources>
                                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="Transparent" />
                                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="Transparent" />
                                        <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent" />
                                        <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Transparent" />
                                    </Button.Resources>
                                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                        <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource ShellSecondaryTextBrush}" Text="Name" VerticalAlignment="Center" />
                                        <FontIcon Glyph="{Binding NameSortGlyph}" FontFamily="Segoe Fluent Icons" FontSize="10" Foreground="{ThemeResource ShellSecondaryTextBrush}" Opacity="{Binding NameSortIndicatorOpacity}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                            <Border Grid.Column="1" Margin="0,4,0,4" Background="{ThemeResource ShellBorderBrush}" />
                            <Grid Grid.Column="2">
                                <Border Background="Transparent" />
                                <Button Background="Transparent" BorderBrush="Transparent" BorderThickness="0" Command="{Binding SortFilesCommand}" CommandParameter="Type" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" MinHeight="28" Padding="14,4,8,4" PointerEntered="FileListHeaderButton_PointerEntered" PointerExited="FileListHeaderButton_PointerExited" PointerPressed="FileListHeaderButton_PointerPressed" PointerReleased="FileListHeaderButton_PointerReleased" PointerCanceled="FileListHeaderButton_PointerCanceled" PointerCaptureLost="FileListHeaderButton_PointerCaptureLost" UseSystemFocusVisuals="False">
                                    <Button.Resources>
                                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="Transparent" />
                                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="Transparent" />
                                        <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent" />
                                        <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Transparent" />
                                    </Button.Resources>
                                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                        <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource ShellSecondaryTextBrush}" Text="Type" VerticalAlignment="Center" />
                                        <FontIcon Glyph="{Binding TypeSortGlyph}" FontFamily="Segoe Fluent Icons" FontSize="10" Foreground="{ThemeResource ShellSecondaryTextBrush}" Opacity="{Binding TypeSortIndicatorOpacity}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                            <Border Grid.Column="3" Margin="0,4,0,4" Background="{ThemeResource ShellBorderBrush}" />
                            <Grid Grid.Column="4">
                                <Border Background="Transparent" />
                                <Button Background="Transparent" BorderBrush="Transparent" BorderThickness="0" Command="{Binding SortFilesCommand}" CommandParameter="Modified" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" MinHeight="28" Padding="14,4,8,4" PointerEntered="FileListHeaderButton_PointerEntered" PointerExited="FileListHeaderButton_PointerExited" PointerPressed="FileListHeaderButton_PointerPressed" PointerReleased="FileListHeaderButton_PointerReleased" PointerCanceled="FileListHeaderButton_PointerCanceled" PointerCaptureLost="FileListHeaderButton_PointerCaptureLost" UseSystemFocusVisuals="False">
                                    <Button.Resources>
                                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="Transparent" />
                                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="Transparent" />
                                        <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent" />
                                        <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Transparent" />
                                    </Button.Resources>
                                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                        <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource ShellSecondaryTextBrush}" Text="Modified" VerticalAlignment="Center" />
                                        <FontIcon Glyph="{Binding ModifiedSortGlyph}" FontFamily="Segoe Fluent Icons" FontSize="10" Foreground="{ThemeResource ShellSecondaryTextBrush}" Opacity="{Binding ModifiedSortIndicatorOpacity}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                            <Border Grid.Column="5" Margin="0,4,0,4" Background="{ThemeResource ShellBorderBrush}" />
                            <Grid Grid.Column="6">
                                <Border Background="Transparent" />
                                <Button Background="Transparent" BorderBrush="Transparent" BorderThickness="0" Command="{Binding SortFilesCommand}" CommandParameter="Size" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" MinHeight="28" Padding="14,4,8,4" PointerEntered="FileListHeaderButton_PointerEntered" PointerExited="FileListHeaderButton_PointerExited" PointerPressed="FileListHeaderButton_PointerPressed" PointerReleased="FileListHeaderButton_PointerReleased" PointerCanceled="FileListHeaderButton_PointerCanceled" PointerCaptureLost="FileListHeaderButton_PointerCaptureLost" UseSystemFocusVisuals="False">
                                    <Button.Resources>
                                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="Transparent" />
                                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="Transparent" />
                                        <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent" />
                                        <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Transparent" />
                                    </Button.Resources>
                                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                        <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource ShellSecondaryTextBrush}" Text="Size" VerticalAlignment="Center" />
                                        <FontIcon Glyph="{Binding SizeSortGlyph}" FontFamily="Segoe Fluent Icons" FontSize="10" Foreground="{ThemeResource ShellSecondaryTextBrush}" Opacity="{Binding SizeSortIndicatorOpacity}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Grid>

                        <ListView x:Name="FilesListView" Grid.Row="1" Margin="0,0,0,8" Background="Transparent" BorderThickness="0" IsItemClickEnabled="False" ItemsSource="{Binding Files}" KeyDown="FilesView_KeyDown" SelectionChanged="FilesView_SelectionChanged" SelectionMode="Extended" Visibility="{Binding FileListVisibility}">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Margin" Value="0" />
                                    <Setter Property="MinHeight" Value="0" />
                                    <Setter Property="Padding" Value="0" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2,0,2" Padding="16,8,16,8" Background="Transparent" DoubleTapped="FilesViewItem_DoubleTapped">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="180" />
                                            <ColumnDefinition Width="160" />
                                            <ColumnDefinition Width="120" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Margin="8,0,0,0" Orientation="Horizontal" Spacing="8">
                                            <Grid Width="16" Height="16" VerticalAlignment="Center">
                                                <Image Width="16" Height="16" Opacity="{Binding NativeIconOpacity}" Source="{Binding IconSource}" Stretch="Uniform" />
                                                <FontIcon Glyph="{Binding Glyph}" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="{ThemeResource ShellTextBrush}" HorizontalAlignment="Center" Opacity="{Binding GlyphOpacity}" VerticalAlignment="Center" />
                                            </Grid>
                                            <TextBlock Foreground="{ThemeResource ShellTextBrush}" Text="{Binding Name}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Margin="14,0,8,0" Foreground="{ThemeResource ShellSecondaryTextBrush}" Text="{Binding ItemType}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2" Margin="14,0,8,0" Foreground="{ThemeResource ShellSecondaryTextBrush}" Text="{Binding Modified}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="3" Margin="14,0,8,0" Foreground="{ThemeResource ShellSecondaryTextBrush}" HorizontalAlignment="Right" Text="{Binding Size}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <GridView x:Name="ThisPcDrivesGridView" Grid.Row="1" Margin="12,12,12,16" Background="Transparent" BorderThickness="0" IsItemClickEnabled="False" ItemsSource="{Binding Files}" KeyDown="FilesView_KeyDown" ScrollViewer.HorizontalScrollBarVisibility="Disabled" SelectionChanged="FilesView_SelectionChanged" SelectionMode="Extended" Visibility="{Binding ThisPcDriveGridVisibility}">
                            <GridView.Resources>
                                <SolidColorBrush x:Key="ListViewItemBackgroundPointerOver" Color="Transparent" />
                                <SolidColorBrush x:Key="ListViewItemBackgroundPressed" Color="Transparent" />
                                <SolidColorBrush x:Key="ListViewItemBackgroundSelected" Color="Transparent" />
                                <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver" Color="Transparent" />
                                <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPressed" Color="Transparent" />
                                <SolidColorBrush x:Key="ListViewItemBorderBrushPointerOver" Color="Transparent" />
                                <SolidColorBrush x:Key="ListViewItemBorderBrushPressed" Color="Transparent" />
                                <SolidColorBrush x:Key="ListViewItemBorderBrushSelected" Color="Transparent" />
                                <SolidColorBrush x:Key="ListViewItemBorderBrushSelectedPointerOver" Color="Transparent" />
                                <SolidColorBrush x:Key="ListViewItemBorderBrushSelectedPressed" Color="Transparent" />
                                <SolidColorBrush x:Key="ListViewItemRevealBorderBrushPointerOver" Color="Transparent" />
                                <SolidColorBrush x:Key="ListViewItemRevealBorderBrushPressed" Color="Transparent" />
                                <SolidColorBrush x:Key="ListViewItemRevealBorderBrushSelected" Color="Transparent" />
                                <SolidColorBrush x:Key="ListViewItemRevealBorderBrushSelectedPointerOver" Color="Transparent" />
                                <SolidColorBrush x:Key="ListViewItemRevealBorderBrushSelectedPressed" Color="Transparent" />
                            </GridView.Resources>
                            <GridView.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsWrapGrid Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </GridView.ItemsPanel>
                            <GridView.ItemContainerStyle>
                                <Style TargetType="GridViewItem">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderBrush" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="UseSystemFocusVisuals" Value="False" />
                                    <Setter Property="FocusVisualPrimaryThickness" Value="0" />
                                    <Setter Property="FocusVisualSecondaryThickness" Value="0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Margin" Value="0" />
                                    <Setter Property="MinHeight" Value="0" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="GridViewItem">
                                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter Content="{TemplateBinding Content}" ContentTemplate="{TemplateBinding ContentTemplate}" ContentTransitions="{TemplateBinding ContentTransitions}" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </GridView.ItemContainerStyle>
                            <GridView.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="352" MinHeight="96" Margin="4,4,12,12" Padding="16,14" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" CornerRadius="8" DoubleTapped="FilesViewItem_DoubleTapped" PointerEntered="ThisPcDriveTile_PointerEntered" PointerExited="ThisPcDriveTile_PointerExited" PointerPressed="ThisPcDriveTile_PointerPressed" PointerReleased="ThisPcDriveTile_PointerReleased" PointerCanceled="ThisPcDriveTile_PointerCanceled" PointerCaptureLost="ThisPcDriveTile_PointerCaptureLost">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Grid Width="32" Height="32" Margin="0,0,14,0" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                <Image Width="32" Height="32" HorizontalAlignment="Left" Opacity="{Binding NativeIconOpacity}" Source="{Binding IconSource}" Stretch="None" VerticalAlignment="Center" />
                                                <FontIcon Glyph="{Binding Glyph}" FontFamily="Segoe Fluent Icons" FontSize="28" Foreground="{ThemeResource ShellTextBrush}" HorizontalAlignment="Left" Opacity="{Binding GlyphOpacity}" VerticalAlignment="Center" />
                                            </Grid>

                                            <Grid Grid.Column="1">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <TextBlock Foreground="{ThemeResource ShellTextBrush}" FontSize="14" FontWeight="SemiBold" Text="{Binding Name}" TextTrimming="CharacterEllipsis" />

                                                <Grid Grid.Row="1" Margin="0,8,0,8" Height="7" Visibility="{Binding DriveUsageVisibility}">
                                                    <Border Background="{ThemeResource ShellButtonBrush}" CornerRadius="2" />
                                                    <Border Background="{ThemeResource ShellAccentBrush}" CornerRadius="2" HorizontalAlignment="Stretch" RenderTransformOrigin="0,0.5" Visibility="{Binding NormalDriveUsageVisibility}">
                                                        <Border.RenderTransform>
                                                            <ScaleTransform ScaleX="{Binding DriveUsageScaleX}" />
                                                        </Border.RenderTransform>
                                                    </Border>
                                                    <Border Background="{ThemeResource ShellCriticalBrush}" CornerRadius="2" HorizontalAlignment="Stretch" RenderTransformOrigin="0,0.5" Visibility="{Binding CriticalDriveUsageVisibility}">
                                                        <Border.RenderTransform>
                                                            <ScaleTransform ScaleX="{Binding DriveUsageScaleX}" />
                                                        </Border.RenderTransform>
                                                    </Border>
                                                </Grid>

                                                <TextBlock Grid.Row="2" Foreground="{ThemeResource ShellSecondaryTextBrush}" FontSize="12" Text="{Binding Size}" TextTrimming="CharacterEllipsis" />
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </GridView.ItemTemplate>
                        </GridView>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="3" Margin="16,12,16,16" Padding="16,8" Background="{ThemeResource ShellChromeBrush}" BorderBrush="{ThemeResource ShellBorderBrush}" BorderThickness="1" CornerRadius="12">
            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <TextBlock Foreground="{ThemeResource ShellSecondaryTextBrush}" Text="{Binding ItemCountSummaryText}" VerticalAlignment="Center" />
                <Border Width="1" Height="16" Background="{ThemeResource ShellBorderBrush}" VerticalAlignment="Center" Visibility="{Binding SelectedItemsSummaryDividerVisibility}" />
                <TextBlock Foreground="{ThemeResource ShellSecondaryTextBrush}" Text="{Binding SelectedItemsSummaryText}" VerticalAlignment="Center" Visibility="{Binding SelectedItemsSummaryVisibility}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>

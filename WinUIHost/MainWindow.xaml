<Window
    x:Class="ExplorerPlusPlus.WinUIHost.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:ExplorerPlusPlus.WinUIHost.Controls"
    Title="Explorer++ WinUI Host">
    <Grid x:Name="RootLayout" Background="{StaticResource ShellBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="16,16,16,0">
            <ItemsControl ItemsSource="{Binding Tabs}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,8,0" Padding="14,8" Background="{StaticResource ShellSurfaceBrush}" BorderBrush="{StaticResource ShellBorderBrush}" BorderThickness="1" CornerRadius="8,8,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="{Binding Glyph}" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="{StaticResource ShellSecondaryTextBrush}" />
                                <TextBlock Text="{Binding Title}" Foreground="{StaticResource ShellTextBrush}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>

        <Border Grid.Row="1" Margin="16,0,16,0" Padding="12" Background="{StaticResource ShellSurfaceBrush}" BorderBrush="{StaticResource ShellBorderBrush}" BorderThickness="1">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Command="{Binding GoBackCommand}" IsEnabled="{Binding Navigation.CanGoBack}">
                    <FontIcon Glyph="&#xE72B;" FontFamily="Segoe Fluent Icons" />
                </Button>
                <Button Grid.Column="1" Command="{Binding GoForwardCommand}" IsEnabled="{Binding Navigation.CanGoForward}">
                    <FontIcon Glyph="&#xE72A;" FontFamily="Segoe Fluent Icons" />
                </Button>
                <Button Grid.Column="2" Command="{Binding GoUpCommand}" IsEnabled="{Binding Navigation.CanGoUp}">
                    <FontIcon Glyph="&#xE74A;" FontFamily="Segoe Fluent Icons" />
                </Button>
                <Button Grid.Column="3" Command="{Binding RefreshCommand}" IsEnabled="{Binding Navigation.CanRefresh}">
                    <FontIcon Glyph="&#xE72C;" FontFamily="Segoe Fluent Icons" />
                </Button>

                <Border Grid.Column="4" Background="{StaticResource ShellBackgroundBrush}" BorderBrush="{StaticResource ShellBorderBrush}" BorderThickness="1" CornerRadius="8">
                    <TextBox Background="Transparent" BorderThickness="0" IsReadOnly="True" Text="{Binding Navigation.CurrentPath}" />
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="16,0,16,16" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Margin="0,16,0,0" Background="{StaticResource ShellSidebarBrush}" BorderBrush="{StaticResource ShellBorderBrush}" BorderThickness="1" CornerRadius="12">
                <ListView x:Name="FoldersPaneListView" Margin="8,10,8,10" Background="Transparent" BorderThickness="0" IsItemClickEnabled="True" ItemClick="FoldersPaneListView_ItemClick" ItemsSource="{Binding FolderPane}" ScrollViewer.HorizontalScrollBarVisibility="Disabled" SelectionMode="None">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="MinHeight" Value="0" />
                            <Setter Property="Padding" Value="0" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,2">
                                <TextBlock Margin="16,12,16,5" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource ShellSidebarSectionBrush}" Text="{Binding Title}" TextWrapping="Wrap" Visibility="{Binding HeaderVisibility}" />
                                <controls:HoverCursorGrid Height="36" PointerEntered="FolderPaneRow_PointerEntered" PointerExited="FolderPaneRow_PointerExited" Visibility="{Binding RowVisibility}">
                                    <Border Margin="6,0" Background="{StaticResource ShellSelectionBrush}" CornerRadius="9" Opacity="{Binding RowBackgroundOpacity}" />
                                    <Grid Margin="{Binding IndentMargin}" VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="6" />
                                            <ColumnDefinition Width="18" />
                                            <ColumnDefinition Width="20" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Width="3" Height="16" Background="{StaticResource ShellAccentBrush}" CornerRadius="2" HorizontalAlignment="Left" Opacity="{Binding SelectionBarOpacity}" VerticalAlignment="Center" />
                                        <Grid Grid.Column="1" Width="18" Height="18" DataContext="{Binding}" IsHitTestVisible="{Binding ChevronHitTestVisible}" Opacity="{Binding ChevronOpacity}" Tapped="FolderPaneChevron_Tapped" VerticalAlignment="Center">
                                            <FontIcon Glyph="{Binding ExpandIndicator}" FontFamily="Segoe Fluent Icons" FontSize="10" Foreground="{StaticResource ShellSecondaryTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Grid>
                                        <Grid Grid.Column="2" Width="16" Height="16" VerticalAlignment="Center">
                                            <Image Width="16" Height="16" Opacity="{Binding NativeIconOpacity}" Source="{Binding IconSource}" Stretch="Uniform" />
                                            <FontIcon Glyph="{Binding Glyph}" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="{StaticResource ShellTextBrush}" HorizontalAlignment="Center" Opacity="{Binding GlyphOpacity}" VerticalAlignment="Center" />
                                        </Grid>
                                        <TextBlock Grid.Column="3" Margin="10,0,10,0" Foreground="{StaticResource ShellTextBrush}" Text="{Binding Title}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                    </Grid>
                                </controls:HoverCursorGrid>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>

            <Border Grid.Column="1" Margin="0,16,0,0" Background="{StaticResource ShellSurfaceBrush}" BorderBrush="{StaticResource ShellBorderBrush}" BorderThickness="1" CornerRadius="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Margin="16,16,16,8" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="120" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource ShellSecondaryTextBrush}" Text="Name" />
                        <TextBlock Grid.Column="1" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource ShellSecondaryTextBrush}" Text="Type" />
                        <TextBlock Grid.Column="2" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource ShellSecondaryTextBrush}" Text="Modified" />
                        <TextBlock Grid.Column="3" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource ShellSecondaryTextBrush}" Text="Size" />
                    </Grid>

                    <ListView x:Name="FilesListView" Grid.Row="1" Margin="8,0,8,8" Background="Transparent" BorderThickness="0" IsItemClickEnabled="True" ItemClick="FilesListView_ItemClick" ItemsSource="{Binding Files}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="8,2" Padding="8,8" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="120" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                        <Grid Width="16" Height="16" VerticalAlignment="Center">
                                            <Image Width="16" Height="16" Opacity="{Binding NativeIconOpacity}" Source="{Binding IconSource}" Stretch="Uniform" />
                                            <FontIcon Glyph="{Binding Glyph}" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="{StaticResource ShellTextBrush}" HorizontalAlignment="Center" Opacity="{Binding GlyphOpacity}" VerticalAlignment="Center" />
                                        </Grid>
                                        <TextBlock Foreground="{StaticResource ShellTextBrush}" Text="{Binding Name}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Foreground="{StaticResource ShellSecondaryTextBrush}" Text="{Binding ItemType}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2" Foreground="{StaticResource ShellSecondaryTextBrush}" Text="{Binding Modified}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="3" Foreground="{StaticResource ShellSecondaryTextBrush}" HorizontalAlignment="Right" Text="{Binding Size}" VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>